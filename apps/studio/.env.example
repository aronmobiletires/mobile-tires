# Copy this file to apps/studio/.env and fill in your project values.
# All values here are placeholders.

# Sanity project ID (from https://www.sanity.io/manage). Required.
SANITY_STUDIO_PROJECT_ID=your-sanity-project-id

# Dataset to read/write from. Defaults to "production" if unset.
SANITY_STUDIO_DATASET=production

# Studio title shown in the browser tab + Studio chrome. Defaults to "Studio" if unset.
SANITY_STUDIO_TITLE=My Site

# Web app origin used by the Presentation tool for live preview. In local dev this
# is the Next.js dev server; in production it should point at the deployed web app.
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000