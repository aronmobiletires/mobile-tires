# Copy this file to apps/web/.env.local and fill in your project values.
# All values here are placeholders.

# Sanity project ID (from https://www.sanity.io/manage). Required.
# Public — exposed to the browser bundle.
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id

# Dataset to read from. Defaults to "production".
NEXT_PUBLIC_SANITY_DATASET=production

# GROQ API version pin. Use today's date in YYYY-MM-DD form when bumping.
NEXT_PUBLIC_SANITY_API_VERSION=2026-01-01

# Public web origin. Used by robots.ts, sitemap.ts, and absolute URL helpers.
# In production, set to the canonical site URL (e.g. https://www.example.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Deployed Studio origin. Click-to-edit overlays in the web app deep-link back
# to this URL. In local dev, leave as localhost:3333.
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# Viewer-role API token (from sanity.io/manage → API → Tokens).
# Required for draft content preview via the Presentation tool. Server-only —
# never expose to the browser. Without this, Presentation still works for
# published content but won't show unpublished drafts.
SANITY_API_READ_TOKEN=

# Secret for validating Sanity webhook revalidation requests. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the secret set in sanity.io/manage → API → Webhooks.
SANITY_REVALIDATE_SECRET=